    "test:frontend:watch": "vitest",
    "watch": "vite --mode development build --watch"
  },
  "browserslist": [
    "extends @nextcloud/browserslist-config"
  ],
  "dependencies": {
    "@nextcloud/axios": "^2.6.0",
    "@nextcloud/dialogs": "^7.4.0",
    "@nextcloud/initial-state": "^3.0.0",
    "@nextcloud/paths": "^3.1.0",
    "@nextcloud/router": "^3.1.0",
    "@nextcloud/vue": "^9.8.2",
    "@types/proj4": "^2.19.0",
    "@types/proj4leaflet": "^1.0.12",
    "geojson-antimeridian-cut": "^0.1.0",
    "leaflet": "^1.9.4",
    "leaflet.geodesic": "^2.7.2",
    "pinia": "^3.0.4",
    "proj4": "^2.20.9",
    "proj4leaflet": "^1.0.2",
    "topojson-client": "^3.1.0",
    "vue": "^3.5.38",
    "vue-material-design-icons": "^5.3.1",
    "vue-router": "^5.1.0",
    "world-atlas": "^2.0.2"
